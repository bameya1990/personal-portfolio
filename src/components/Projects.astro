---
const projects = [
  {
    company: "Shopify",
    year: "2022–2024",
    title: "Subscription Platform",
    description:
      "Optimized Shopify's core platform for subscription-based businesses, leading cross-functional product development with engineering, design, go-to-market, and support teams. Shipped fraud protection for subscription payments within a 6-week cycle.",
    impact: "$3B",
    impactLabel: "Revenue Platform",
    impactDetail: "Platform serving $3B in subscription commerce",
    tags: ["Platform", "Subscriptions", "Payments", "Fraud Prevention"],
  },
  {
    company: "Shopify",
    year: "2022–2024",
    title: "Subscription Data Migration Tool",
    description:
      "Championed end-to-end development from user interviews and project scoping through competitive analysis, feature prioritization, post-launch tracking and go-to-market documentation. Enabled subscription merchants to migrate from legacy tools.",
    impact: "$1.6M",
    impactLabel: "Revenue Transferred",
    impactDetail: "Merchants migrated from legacy platforms to Shopify",
    tags: ["0→1 Product", "B2B", "Data Migration", "User Research"],
  },
  {
    company: "Shopify",
    year: "2022–2024",
    title: "Checkout Delivery Options",
    description:
      "Led the launch of new delivery options at checkout for subscription products by crafting product requirements, aligning stakeholders across checkout and shipping teams, managing risk, and overseeing deployment.",
    impact: "+$1.3M",
    impactLabel: "Incremental Revenue",
    impactDetail: "New revenue stream added through checkout optimization",
    tags: ["Checkout", "Subscriptions", "Revenue Growth", "Stakeholder Mgmt"],
  },
  {
    company: "Shopify Logistics",
    year: "2022–2024",
    title: "Supply Chain Forecasting & Vendor Selection",
    description:
      "Implemented new demand forecasting processes at warehouses and led a comprehensive vendor evaluation for supply chain planning software. Assessed 6+ vendors and delivered data-driven recommendations to the executive team.",
    impact: "95%",
    impactLabel: "Forecast Accuracy",
    impactDetail: "30% reduction in excess inventory · $2M+ vendor decision",
    tags: ["Supply Chain", "Operations", "Analytics", "Vendor Management"],
  },
];
---

<section id="projects" class="py-28 max-w-6xl mx-auto px-6">
  <!-- Section header -->
  <div class="mb-16">
    <span
      class="text-xs font-semibold text-violet-400 tracking-[0.2em] uppercase"
      >Featured Work</span
    >
    <h2
      class="font-['Syne'] text-4xl md:text-5xl font-black text-zinc-100 mt-3 tracking-tight"
    >
      Products I've Shipped
    </h2>
    <p class="text-zinc-500 mt-3 max-w-xl text-[15px]">
      Selected highlights from my work — each driven by a customer problem and
      measured by real business outcomes.
    </p>
  </div>

  <!-- Projects grid -->
  <div class="grid md:grid-cols-2 gap-5">
    {
      projects.map((project) => (
        <div class="group relative p-8 rounded-2xl border bg-zinc-900/50 border-zinc-800 hover:border-violet-500/40 transition-all duration-300 hover:shadow-2xl hover:shadow-violet-500/5 cursor-default overflow-hidden">
          <!-- Hover glow -->
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-violet-600/5 to-cyan-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" />

          <!-- Company + year -->
          <div class="flex items-center justify-between mb-5">
            <span class="text-xs font-bold tracking-[0.15em] text-zinc-500 uppercase">
              {project.company}
            </span>
            <span class="text-xs text-zinc-700 font-mono">{project.year}</span>
          </div>

          <!-- Impact metric — leads the card -->
          <div class="mb-5">
            <div class="flex items-baseline gap-2">
              <span class="font-['Syne'] text-4xl font-black bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-transparent">
                {project.impact}
              </span>
              <span class="text-sm font-semibold text-zinc-400">
                {project.impactLabel}
              </span>
            </div>
            <p class="text-xs text-zinc-600 mt-0.5">{project.impactDetail}</p>
          </div>

          <!-- Title -->
          <h3 class="font-['Syne'] text-xl font-bold text-zinc-100 mb-3">
            {project.title}
          </h3>

          <!-- Description -->
          <p class="text-sm text-zinc-400 leading-relaxed mb-6">
            {project.description}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="px-3 py-1 text-xs font-medium bg-zinc-800/80 text-zinc-400 rounded-full border border-zinc-700/60">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
