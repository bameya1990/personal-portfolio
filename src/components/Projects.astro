---
const projects = [
  {
    number: "01",
    company: "Shopify",
    title: "Subscription Platform",
    impact: "$3B revenue platform",
    description:
      "Optimized Shopify's core platform for subscription-based businesses. Led cross-functional development with engineering, design, go-to-market, and support. Shipped fraud protection within a 6-week cycle.",
    tags: ["Platform", "Subscriptions", "Payments", "Fraud Prevention"],
    period: "2022–2024",
  },
  {
    number: "02",
    company: "Shopify",
    title: "Subscription Data Migration Tool",
    impact: "$1.6M in revenue transferred",
    description:
      "Led end-to-end development from user interviews and scoping through competitive analysis, feature prioritization, and go-to-market. Enabled merchants to migrate from legacy tools to Shopify.",
    tags: ["0→1", "B2B", "Data Migration", "User Research"],
    period: "2022–2024",
  },
  {
    number: "03",
    company: "Shopify",
    title: "Checkout Delivery Options",
    impact: "+$1.3M incremental revenue",
    description:
      "Launched new delivery options at checkout for subscription products. Crafted product requirements, aligned stakeholders across checkout and shipping teams, managed risk, and oversaw deployment.",
    tags: ["Checkout", "Subscriptions", "Revenue Growth"],
    period: "2022–2024",
  },
  {
    number: "04",
    company: "Shopify Logistics",
    title: "Supply Chain Forecasting",
    impact: "95% forecast accuracy",
    description:
      "Implemented new demand forecasting processes reducing excess inventory by 30%. Led vendor evaluation for a $2M+ supply chain software investment across 6+ vendors.",
    tags: ["Supply Chain", "Operations", "Analytics", "Vendor Management"],
    period: "2022–2024",
  },
];
---

<section id="projects" class="py-24 border-t border-gray-100">
  <div class="max-w-5xl mx-auto px-6">

    <h2 class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-12">
      Featured Work
    </h2>

    <div class="grid md:grid-cols-2 gap-px bg-gray-100">
      {projects.map((project) => (
        <div class="bg-white p-10 hover:bg-gray-50 transition-colors group">
          <div class="flex items-start justify-between mb-6">
            <span class="text-xs text-gray-300 font-medium">{project.number}</span>
            <span class="text-xs text-gray-400">{project.period}</span>
          </div>

          <p class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-2">
            {project.company}
          </p>

          <h3 class="text-xl font-semibold text-gray-900 mb-3 leading-snug">
            {project.title}
          </h3>

          <p class="text-sm font-medium text-gray-900 mb-4">
            {project.impact}
          </p>

          <p class="text-sm text-gray-500 leading-relaxed mb-6">
            {project.description}
          </p>

          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="text-xs text-gray-400 border border-gray-200 px-3 py-1">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
