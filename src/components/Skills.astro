---
const skillGroups = [
  {
    category: "Product",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3" /></svg>`,
    skills: [
      "Roadmapping",
      "User Research",
      "Market Research",
      "A/B Testing",
      "Data Analytics",
      "Go-to-Market",
      "Feature Prioritization",
      "Post-Launch Tracking",
      "Demand Planning",
      "Process Mapping",
      "Competitive Analysis",
      "Customer Support",
    ],
  },
  {
    category: "Leadership",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
    skills: [
      "Stakeholder Management",
      "Cross-Functional Teams",
      "Executive Communications",
      "Change Management",
      "Vendor Management",
      "Team Leadership",
      "Project Management",
    ],
  },
  {
    category: "Technical",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>`,
    skills: [
      "Python",
      "SQL",
      "API Development",
      "Figma",
      "Github",
      "Asana",
      "Zendesk",
      "Claude Code",
      "Gemini CLI",
    ],
  },
];
---

<section id="skills" class="py-28 border-t border-zinc-800/50">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="mb-16">
      <span
        class="text-xs font-semibold text-violet-400 tracking-[0.2em] uppercase"
        >Capabilities</span
      >
      <h2
        class="font-['Syne'] text-4xl md:text-5xl font-black text-zinc-100 mt-3 tracking-tight"
      >
        Skills & Expertise
      </h2>
    </div>

    <!-- Skills grid -->
    <div class="grid md:grid-cols-3 gap-6">
      {
        skillGroups.map((group) => (
          <div class="p-8 rounded-2xl bg-zinc-900/40 border border-zinc-800 hover:border-zinc-700 transition-colors duration-300">
            <div class="flex items-center gap-3 mb-6">
              <span class="text-violet-400" set:html={group.icon} />
              <h3 class="font-['Syne'] font-bold text-lg text-zinc-100">
                {group.category}
              </h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {group.skills.map((skill) => (
                <span class="px-3 py-1.5 text-sm bg-zinc-800/70 text-zinc-300 rounded-lg border border-zinc-700/50 hover:border-violet-500/50 hover:text-violet-300 transition-all duration-200 cursor-default">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
