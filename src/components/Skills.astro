---
const skillGroups = [
  {
    category: "Product",
    skills: [
      "Roadmapping",
      "User Research",
      "Market Research",
      "A/B Testing",
      "Data Analytics",
      "Go-to-Market",
      "Feature Prioritization",
      "Post-Launch Tracking",
      "Demand Planning",
      "Process Mapping",
      "Competitive Analysis",
    ],
  },
  {
    category: "Leadership",
    skills: [
      "Stakeholder Management",
      "Cross-Functional Teams",
      "Executive Communications",
      "Change Management",
      "Vendor Management",
      "Team Leadership",
      "Project Management",
    ],
  },
  {
    category: "Technical",
    skills: [
      "Python",
      "SQL",
      "API Development",
      "Figma",
      "Github",
      "Asana",
      "Zendesk",
      "Claude Code",
      "Gemini CLI",
    ],
  },
];
---

<section id="skills" class="py-24 border-t border-gray-100">
  <div class="max-w-5xl mx-auto px-6">

    <h2 class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-12">
      Skills & Expertise
    </h2>

    <div class="grid md:grid-cols-3 gap-12">
      {skillGroups.map((group) => (
        <div>
          <h3 class="text-sm font-semibold text-gray-900 mb-5">{group.category}</h3>
          <ul class="space-y-2">
            {group.skills.map((skill) => (
              <li class="text-sm text-gray-500">{skill}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>
