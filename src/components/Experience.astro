---
const experiences = [
  {
    company: "Fulfil.io",
    companyDesc: "Enterprise resource planning for e-commerce operations",
    role: "Customer Success Associate (Contract)",
    period: "Aug 2025 – Nov 2025",
    highlights: [
      "Led voice of customer initiatives during backend infrastructure changes, collaborating cross-functionally with Product, Implementation, and Engineering teams",
      "Ensured 0% downtime during API migration and improved system reliability by 25%",
    ],
  },
  {
    company: "Shopify",
    companyDesc: "Commerce platform serving millions of merchants worldwide",
    role: "Product Manager, Platform",
    period: "March 2022 – Sept 2024",
    highlights: [
      "Optimized core platform for subscription-based businesses contributing $3B in revenue",
      "Shipped fraud protection for subscription payments within a 6-week cycle",
      "Championed end-to-end development of data migration tool transferring $1.6M in revenue from legacy tools",
      "Led launch of delivery options at checkout adding $1.3M in incremental revenue",
      "Promoted to full-time role by graduating apprentice program ahead of cohort",
    ],
  },
  {
    company: "Shopify Logistics",
    companyDesc: "",
    role: "Program Manager / Supply Chain Planner",
    period: "2022–2024",
    highlights: [
      "Implemented demand forecasting processes reducing excess packaging inventory by 30% and achieving 95% forecast accuracy",
      "Led vendor evaluation for $2M+ supply chain software investment across 6+ vendors",
    ],
  },
  {
    company: "Fulfil.io",
    companyDesc: "Enterprise resource planning for e-commerce operations",
    role: "Product Support Specialist",
    period: "Dec 2020 – Feb 2022",
    highlights: [
      "Improved retention and customer satisfaction metrics by 40% quarter-over-quarter",
      "Built scalable knowledge management system, consistently reducing support ticket volume QoQ",
    ],
  },
  {
    company: "Counter.app",
    companyDesc: "Early-stage property management software for backpacker hostels",
    role: "Core Product & Operations",
    period: "2018 – 2020",
    highlights: [
      "Core member building product from ideation to launch, including an automated data migration tool",
      "Implemented SOPs across 3 properties driving 80% revenue growth",
    ],
  },
  {
    company: "Amazon",
    companyDesc: "",
    role: "Warehouse Operations Manager",
    period: "2017",
    highlights: [
      "Achieved 98% pick accuracy through workforce planning, performance tracking, and quality control",
      "Reduced employee turnover by 10%, saving $150K annually in recruitment costs",
    ],
  },
];

const education = [
  {
    institution: "University of Michigan – Ann Arbor",
    degree: "Master of Science in Operations Management",
    period: "2015 – 2016",
    detail: "GPA 3.58 / 4.0 · Fellow, Tauber Institute for Global Operations, Stephen M. Ross School of Business",
  },
  {
    institution: "MSRIT India",
    degree: "Bachelor of Engineering in Mechanical Engineering",
    period: "2008 – 2012",
    detail: "GPA 9.42 / 10.0",
  },
];
---

<section id="experience" class="py-28 border-t border-zinc-800/50">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="mb-16">
      <span
        class="text-xs font-semibold text-violet-400 tracking-[0.2em] uppercase"
        >Background</span
      >
      <h2
        class="font-['Syne'] text-4xl md:text-5xl font-black text-zinc-100 mt-3 tracking-tight"
      >
        Experience & Education
      </h2>
    </div>

    <div class="grid lg:grid-cols-[3fr_2fr] gap-16 items-start">
      <!-- Experience timeline -->
      <div>
        <h3
          class="text-xs font-semibold text-zinc-600 uppercase tracking-[0.2em] mb-10"
        >
          Work History
        </h3>
        <div class="relative">
          <!-- Timeline line -->
          <div
            class="absolute left-0 top-2 bottom-0 w-px bg-gradient-to-b from-violet-500/60 via-zinc-700/50 to-transparent"
          ></div>

          <div class="space-y-8">
            {
              experiences.map((exp) => (
                <div class="relative pl-8">
                  <!-- Timeline dot -->
                  <div class="absolute left-[-4.5px] top-[7px] w-[9px] h-[9px] rounded-full bg-violet-500 ring-4 ring-[#09090b]" />

                  <div class="p-6 rounded-xl bg-zinc-900/30 border border-zinc-800 hover:border-zinc-700 transition-colors duration-300">
                    <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
                      <span class="font-['Syne'] font-bold text-zinc-100 text-[17px]">
                        {exp.company}
                      </span>
                      <span class="text-xs text-zinc-600 font-mono shrink-0">
                        {exp.period}
                      </span>
                    </div>
                    <div class="text-sm text-violet-400 font-medium mb-1">
                      {exp.role}
                    </div>
                    {exp.companyDesc && (
                      <div class="text-xs text-zinc-600 italic mb-3">
                        {exp.companyDesc}
                      </div>
                    )}
                    <ul class="space-y-2 mt-3">
                      {exp.highlights.map((h) => (
                        <li class="text-[13.5px] text-zinc-400 flex gap-2.5 leading-relaxed">
                          <span class="text-violet-500 mt-[2px] flex-shrink-0 font-bold">
                            ›
                          </span>
                          <span>{h}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Education + About column -->
      <div class="space-y-6">
        <h3
          class="text-xs font-semibold text-zinc-600 uppercase tracking-[0.2em] mb-10"
        >
          Education
        </h3>

        {
          education.map((edu) => (
            <div class="p-6 rounded-xl bg-zinc-900/30 border border-zinc-800 hover:border-zinc-700 transition-colors duration-300">
              <div class="text-xs text-zinc-600 font-mono mb-2">
                {edu.period}
              </div>
              <div class="font-['Syne'] font-bold text-zinc-100 mb-1 text-[15px]">
                {edu.institution}
              </div>
              <div class="text-sm text-violet-400 font-medium mb-2">
                {edu.degree}
              </div>
              <div class="text-xs text-zinc-500 leading-relaxed">{edu.detail}</div>
            </div>
          ))
        }

        <!-- About callout -->
        <div
          class="p-6 rounded-xl bg-gradient-to-br from-violet-900/20 to-cyan-900/10 border border-violet-500/20 mt-4"
        >
          <h4 class="font-['Syne'] font-bold text-zinc-100 mb-3 text-[15px]">
            About Me
          </h4>
          <p class="text-sm text-zinc-400 leading-relaxed">
            Versatile PM known for taking on mission-critical initiatives and
            delivering with resourcefulness and creativity. I bridge the gap
            between technical complexity and real business value — from 0→1
            builds to platform-scale optimization.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
