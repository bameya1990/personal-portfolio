<section class="min-h-screen flex flex-col justify-center pt-20 pb-16">
  <div class="max-w-5xl mx-auto px-6 w-full">

    <!-- Name -->
    <h1 class="text-5xl md:text-7xl font-bold text-gray-900 leading-tight tracking-tight mb-8">
      Ameya Bongale.
    </h1>

    <!-- Role description — mirrors the reference site's pattern -->
    <p class="text-xl md:text-2xl font-light text-gray-600 max-w-2xl leading-relaxed mb-10">
      Product Manager who is Revenue-Focused,<br class="hidden md:block" />
      Platform-Savvy, and Execution-Oriented.
    </p>

    <!-- Short bio -->
